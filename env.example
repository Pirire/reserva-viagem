# ═══════════════════════════════════════════════════════════
# .env.example — MAPA das variáveis de ambiente (SEM valores)
# ───────────────────────────────────────────────────────────
# Este ficheiro serve de referência: lista TODAS as variáveis
# que o projeto precisa, sem os segredos. Vai para o git.
# Os valores REAIS ficam no .env (que NUNCA vai para o git).
# Para montar o projeto: copia este ficheiro para .env e
# preenche cada valor com os teus segredos reais.
# ═══════════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────────
PORT=

# ── BASE DE DADOS ─────────────────────────────────────────
MONGODB_URI=

# ── URLS ──────────────────────────────────────────────────
FRONTEND_BASE_URL=
PUBLIC_BASE_URL=
SUCCESS_URL=
CANCEL_URL=
APP_URL=

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=
ADMIN_JWT_SECRET=
INVITE_JWT_SECRET=
PARTILHA_ADMIN_KEY=

# ── PAINEL ADMIN ──────────────────────────────────────────
ADMIN_USER_MASTER=
ADMIN_PASS_MASTER=
ADMIN_SETTINGS_MASTER_KEY=
ADMIN_USER_RESERVA=
ADMIN_PASS_RESERVA=
ADMIN_EMAIL=

# ── SMTP (emails) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# ── TWILIO (SMS) ──────────────────────────────────────────
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_ENABLED=

# ── GOOGLE MAPS ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── PAYPAL ────────────────────────────────────────────────
PAYPAL_MODE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── STRIPE ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# ── FATURAÇÃO ─────────────────────────────────────────────
IVA_PERCENT=
EMPRESA_NIF=
EMPRESA_NOME=
CORS_ORIGINS=
